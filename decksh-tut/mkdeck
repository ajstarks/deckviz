#!/bin/bash
./mkpage first
./mkpage vars
./mkpage coord
./mkpage colors
./mkpage text
./mkpage image
./mkpage graphics
./mkpage fgraphics
./mkpage list
./mkpage chart
./mkpage loop
./mkpage geo -layers="poly:image:ellipse:text:line:rect"
decksh tut.dsh |
pdfdeck -sw \
 -stdout \
 -sans PublicSans-Regular \
 -mono Inconsolata-Medium \
 -serif Charter-Regular - > tut.pdf